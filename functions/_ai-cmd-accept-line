#!/usr/bin/env zsh
# ZLE widget: override accept-line to intercept "# " prefixed natural language

_ai-cmd-accept-line() {
  local prefix="${AI_CMD_PREFIX:-# }"

  # Check if buffer starts with the AI prefix and has content after it
  if [[ "$BUFFER" == "${prefix}"* && ${#BUFFER} -gt ${#prefix} ]]; then
    # Save original input for regeneration (Ctrl+R)
    typeset -g _AI_CMD_LAST_INPUT="$BUFFER"

    local nl_input="${BUFFER#${prefix}}"

    local context api_input
    local is_commit=""

    if [[ "$nl_input" == commit* ]]; then
      # Commit mode: gather git context
      is_commit="true"
      local hint="${nl_input#commit}"
      hint="${hint## }"

      POSTDISPLAY=$'\n'"  ... generating commit message"
      zle reset-prompt

      local commit_err=$(mktemp)
      context=$(_ai-cmd-context-commit 2>"$commit_err")
      local ctx_code=$?
      local ctx_err=$(<"$commit_err")
      command rm -f "$commit_err"

      if [[ $ctx_code -ne 0 || -z "$context" ]]; then
        POSTDISPLAY=$'\n'"  [!] ${ctx_err:-Not a git repo or no changes to commit.}"
        region_highlight=()
        zle reset-prompt
        return 1
      fi

      api_input="generate commit message${hint:+: $hint}"
    elif [[ "$nl_input" == pr* ]]; then
      # PR mode: gather branch context
      local hint="${nl_input#pr}"
      hint="${hint## }"

      POSTDISPLAY=$'\n'"  ... generating PR command"
      zle reset-prompt

      local pr_err=$(mktemp)
      context=$(_ai-cmd-context-pr 2>"$pr_err")
      local ctx_code=$?
      local ctx_err=$(<"$pr_err")
      command rm -f "$pr_err"

      if [[ $ctx_code -ne 0 || -z "$context" ]]; then
        POSTDISPLAY=$'\n'"  [!] ${ctx_err:-Not a git repo or no branch to create PR from.}"
        region_highlight=()
        zle reset-prompt
        return 1
      fi

      api_input="generate gh pr create command${hint:+: $hint}"
    else
      # Normal mode: natural language to command
      context=$(_ai-cmd-context 2>/dev/null)
      api_input="$nl_input"

      POSTDISPLAY=$'\n'"  ... translating to command"
      zle reset-prompt
    fi

    # Call AI API (capture stderr for error messages)
    local tmp_err=$(mktemp)
    local generated_cmd
    generated_cmd=$(_ai-cmd-call-api "$api_input" "$context" 2>"$tmp_err")
    local exit_code=$?
    local err_msg=$(<"$tmp_err")
    command rm -f "$tmp_err"

    # Clear decorations
    POSTDISPLAY=""
    region_highlight=()

    if [[ $exit_code -ne 0 || -z "$generated_cmd" ]]; then
      local display_err="${err_msg:-Check API key and network.}"
      POSTDISPLAY=$'\n'"  [!] ${display_err}"
      zle reset-prompt
      return 1
    fi

    # Sanitize the response
    generated_cmd=$(_ai-cmd-sanitize "$generated_cmd")

    # For commit mode: prepend git add -u if changes aren't staged
    if [[ "$is_commit" == "true" && "$context" == NEEDS_STAGING* ]]; then
      generated_cmd="git add -u && ${generated_cmd}"
    fi

    # Replace buffer with generated command
    BUFFER="$generated_cmd"
    CURSOR=${#BUFFER}

    # Safety check
    if [[ "${AI_CMD_SAFETY}" == "true" ]] && ! _ai-cmd-safety "$generated_cmd"; then
      POSTDISPLAY=$'\n'"  [!] WARNING: Potentially dangerous command! Review carefully before pressing Enter."
      region_highlight=("0 ${#BUFFER} fg=red,bold")
    else
      POSTDISPLAY=$'\n'"  [ok] Press Enter to execute, Ctrl+R to regenerate, Ctrl+C to cancel"
      region_highlight=("0 ${#BUFFER} fg=green")
    fi

    zle reset-prompt
    # Do NOT call .accept-line — let the user review and press Enter again
    return 0
  fi

  # Not an AI command — clear decorations and pass through
  POSTDISPLAY=""
  region_highlight=()
  zle .accept-line
}

_ai-cmd-accept-line "$@"
